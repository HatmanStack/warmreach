{
  "name": "warmreach-client",
  "version": "1.14.0",
  "description": "WarmReach client — Electron tray app with Puppeteer automation",
  "main": "electron-main.js",
  "type": "module",
  "imports": {
    "#utils/*": "./src/shared/utils/*",
    "#shared-config/*": "./src/shared/config/*",
    "#shared/*": "./src/shared/*",
    "#config": "./config/index.js",
    "#routes/*": "./routes/*",
    "#schemas/*": "./schemas/*"
  },
  "scripts": {
    "start": "node --import tsx src/server.js",
    "dev": "nodemon --exec 'node --import tsx' src/server.js",
    "electron:dev": "electron --import tsx electron-main.js",
    "electron:build": "npm run build:ts && electron-builder --publish never && npm run clean:ts",
    "build:ts": "tsc -p tsconfig.build.json && node scripts/copy-emitted.mjs",
    "clean:ts": "find src config routes -name '*.ts' ! -name '*.test.ts' -exec sh -c 'rm -f \"${0%.ts}.js\"' {} \\; && find src config routes -name '*.cts' -exec sh -c 'rm -f \"${0%.cts}.cjs\"' {} \\; && rm -rf build-tsc",
    "build": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "libsodium-wrappers-sumo": "^0.8.4",
    "puppeteer": "^24.42.0",
    "tsx": "^4.19.2",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.16"
  },
  "author": "Your Name",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "qs": "^6.14.1"
  }
}